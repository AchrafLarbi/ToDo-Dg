# Copiez ce fichier en ".env" et completez les valeurs pour un usage local.
# En production sur Render, ces valeurs sont definies comme variables d'environnement
# du service (voir render.yaml), pas dans un fichier .env.

# URL de connexion PostgreSQL (fournie automatiquement par Render si vous utilisez render.yaml)
DATABASE_URL=postgresql://user:password@localhost:5432/gestion_taches

# Cle secrete Flask (sessions/cookies) - generez une valeur aleatoire unique
SECRET_KEY=changez-moi-en-une-valeur-aleatoire-longue

# Mot de passe pour se connecter a l'interface d'administration
ADMIN_PASSWORD=changez-moi
